{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "Grep",
      "Glob",
      "LS",
      "MultiEdit",
      "NotebookRead",
      "NotebookEdit",
      "TodoRead",
      "TodoWrite",
      "WebSearch"
    ],
    "deny": [
      "Bash(taskkill:*/F:*/IM:*node.exe:*)",
      "Bash(taskkill:*node.exe:*)",
      "Bash(killall:*node:*)",
      "Bash(pkill:*-f:*node:*)",
      "Bash(drizzle-kit:*push:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); style=$(echo \"$input\" | jq -r '.output_style.name'); printf \"\\033[2m%s\\033[0m \\033[36m%s\\033[0m \\033[33m%s\\033[0m\" \"$model\" \"$(basename \"$cwd\")\" \"[$style]\""
  },
  "alwaysThinkingEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754060234431
  }
}
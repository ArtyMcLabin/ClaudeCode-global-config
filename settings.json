{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {},
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "Grep",
      "Glob",
      "LS",
      "MultiEdit",
      "NotebookRead",
      "NotebookEdit",
      "TodoRead",
      "TodoWrite",
      "WebSearch",
      "Skill(email-triage)",
      "Skill(google-gmail)",
      "Skill(google-sheets)",
      "Skill(airwallex-transfers)",
      "Skill(podcast-guest-mgmt)",
      "Skill(sop-copypasta)",
      "Skill(knowledge-architecture)",
      "Skill(skill-creation)",
      "Skill(trello-fetch)"
    ],
    "deny": [
      "Bash(taskkill:*/F:*/IM:*node.exe:*)",
      "Bash(taskkill:*node.exe:*)",
      "Bash(killall:*node:*)",
      "Bash(pkill:*-f:*node:*)",
      "Bash(drizzle-kit:*push:*)",
      "mcp__google-workspace__drive_search",
      "mcp__google-workspace__drive_findFolder",
      "mcp__google-workspace__drive_createFolder",
      "mcp__google-workspace__drive_downloadFile"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); style=$(echo \"$input\" | jq -r '.output_style.name'); printf \"\\033[2m%s\\033[0m \\033[36m%s\\033[0m \\033[33m%s\\033[0m\" \"$model\" \"$(basename \"$cwd\")\" \"[$style]\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__google-workspace__gmail_send|mcp__google-workspace__gmail_sendDraft",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'BLOCKED: Use mcp__gmail__send_email instead. mcp__google-workspace__gmail_send silently breaks threading. See google-gmail skill.' && exit 2",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import json,sys,re;d=json.load(sys.stdin);cmd=d.get('tool_input',{}).get('command','');m=re.search(r'\\bgh\\s+issue\\b',cmd);sys.exit(0) if not m else (print('BLOCKED: Use github-issue-manager subagent via Task tool for ALL GitHub issue operations. Never use gh issue CLI directly. See CLAUDE.md.',file=sys.stderr) or sys.exit(2))\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os;exec(open(os.path.expanduser('~/.claude/skills/db-safety/scripts/preToolUse-block-prod-bypass.py')).read())\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__gmail_send|mcp__google-workspace__gmail_createDraft|mcp__google-workspace__gmail_sendDraft|mcp__gmail__send_email|mcp__gmail__draft_email",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os;exec(open(os.path.expanduser('~/.claude/skills/message-drafting/scripts/preToolUse-reminder.py')).read())\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|mcp__google-workspace__gmail_send|mcp__google-workspace__gmail_createDraft|mcp__google-workspace__gmail_sendDraft|mcp__gmail__send_email|mcp__gmail__draft_email",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os;exec(open(os.path.expanduser('~/.claude/skills/message-drafting/scripts/preToolUse-email-verification.py')).read())\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os;exec(open(os.path.expanduser('~/.claude/skills/knowledge-architecture/scripts/preToolUse-block-knowledge-files.py')).read())\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os;exec(open(os.path.expanduser('~/.claude/skills/dev-loop/scripts/preToolUse-block-push-without-tests.py')).read())\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os;exec(open(os.path.expanduser('~/.claude/skills/dev-loop/scripts/postToolUse-mark-tests-run.py')).read())\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os;exec(open(os.path.expanduser('~/.claude/skills/knowledge-architecture/scripts/postToolUse-reminder.py')).read())\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os;exec(open(os.path.expanduser('~/.claude/skills/dev-loop/scripts/postToolUse-mark-code-edits.py')).read())\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os;exec(open(os.path.expanduser('~/.claude/skills/autonomous-issue-dispatch/scripts/stop-verify-pipeline.py')).read())\"",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "model": "opus"
}
